# Copy this file to .env.local for local development.

NEXT_PUBLIC_APP_NAME=DocuMind

# Local Docker Compose PostgreSQL database.
DATABASE_URL=postgresql://documind:documind@localhost:5432/documind?schema=public

# Generate a strong value for real deployments:
# openssl rand -base64 32
AUTH_SECRET=replace-with-a-strong-random-secret
AUTH_TRUST_HOST=true

# Optional OAuth providers. Buttons appear only when both ID and secret are set.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Server-side OpenAI API key for embeddings, search, and grounded answers.
# Never expose this as NEXT_PUBLIC_*.
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ANSWER_MODEL=gpt-5-mini

# Optional local bootstrap account created by `npm run prisma:seed`.
SEED_USER_EMAIL=seed@documind.local
SEED_USER_PASSWORD=DocuMindSeed123!
