# Copy this file to .env.local for local development.

NEXT_PUBLIC_APP_NAME=DocuMind

# Local Docker Compose PostgreSQL database.
DATABASE_URL=postgresql://documind:documind@localhost:5432/documind?schema=public

# Generate a strong value for real deployments:
# openssl rand -base64 32
AUTH_SECRET=replace-with-a-strong-random-secret
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Optional OAuth providers. Buttons appear only when both ID and secret are set.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Optional email delivery through Resend.
# Without these values, reset requests stay non-enumerating and team invitations
# still return shareable links, but users will not receive production emails.
PASSWORD_RESET_BASE_URL=http://localhost:3000
PASSWORD_RESET_EMAIL_FROM=
TEAM_INVITATION_EMAIL_FROM=
RESEND_API_KEY=

# Local development only. When true outside production, forgot-password returns
# a reset link in the response so the flow can be tested without email delivery.
PASSWORD_RESET_DEBUG_LINKS=false

# Document storage. Use local for development or vercel-blob for durable
# production uploads on Vercel.
DOCUMENT_STORAGE_PROVIDER=local
BLOB_READ_WRITE_TOKEN=

# Server-side OpenAI API key for embeddings, search, and grounded answers.
# Never expose this as NEXT_PUBLIC_*.
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ANSWER_MODEL=gpt-5-mini

# Optional local bootstrap account created by `npm run prisma:seed`.
SEED_USER_EMAIL=seed@documind.local
SEED_USER_PASSWORD=DocuMindSeed123!
